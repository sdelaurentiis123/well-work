# Template for .env — copy to .env (gitignored) and fill in actual keys.
# Never commit .env. Rotate any exposed key via the respective service.

# HuggingFace read-only token — https://huggingface.co/settings/tokens
export HF_TOKEN=hf_...
export HUGGING_FACE_HUB_TOKEN="$HF_TOKEN"
export HF_HUB_ENABLE_HF_TRANSFER=1

# Weights & Biases — https://wandb.ai/settings
export WANDB_API_KEY=wandb_v1_...
export WANDB_PROJECT=well-work-p1

# Vast.ai — https://cloud.vast.ai/account/ → Keys
export VAST_API_KEY=...

# Usage:
#   source .env
#   vastai show instances
#   wandb login "$WANDB_API_KEY"
